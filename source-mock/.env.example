# DiDO ingest CLI configuration — copy to `.env` and fill in.
# Real env vars override any value set here.

# Base URL of the running gbrain HTTP server.
GBRAIN_BASE_URL=http://localhost:8787

# OAuth client_credentials. Mint these on the gbrain host with:
#
#   gbrain auth register-client dido-ingest \
#       --grant-types client_credentials \
#       --scopes "read write"
#
# IMPORTANT: the bare `register-client` defaults to the `read` scope only,
# which makes POST /ingest return 403. You MUST pass --scopes "read write".
GBRAIN_CLIENT_ID=gbrain_cl_xxxxxxxxxxxx
GBRAIN_CLIENT_SECRET=gbrain_cs_xxxxxxxxxxxx

# --- Optional (defaults shown) ---
# Scopes requested at token mint; must include `write` for /ingest.
# GBRAIN_SCOPES=read write
# Input root scanned for sources/<source>/<YYYY-MM-DD>/<Title>.md
# GBRAIN_SOURCES_DIR=sources
# Where the ledger + per-run logs are written (gitignored).
# GBRAIN_LOG_DIR=.ingest-logs
# Client-side payload cap in bytes (mirrors the server's 1 MB default).
# GBRAIN_MAX_BYTES=1048576
